# ============================================================
#  ⚠️  NE JAMAIS COMMITTER LE FICHIER .env
#     Copier ce fichier en .env et remplir les valeurs
#     docker compose vérifie que .env existe et l'ignore dans git
# ============================================================

# ─── Base de données ─────────────────────────────────────
POSTGRES_PASSWORD=changer_moi_postgres

# ─── Redis ───────────────────────────────────────────────
REDIS_PASSWORD=changer_moi_redis

# ─── NATS (pas de mot de passe, basé sur réseau privé) ──

# ─── ClickHouse (analytics) ──────────────────────────────
CLICKHOUSE_PASSWORD=changer_moi_clickhouse

# ─── Application ─────────────────────────────────────────
JWT_SECRET=changer_moi_jwt_secret_tres_long

# ─── Monitoring ──────────────────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=changer_moi_grafana

# ─── API Gateway (automatique via compose) ─────────────
PORT=8080
GIN_MODE=release
