# ⚠️ NE JAMAIS COMMITTER LE VRAI secrets.yaml
# Ce fichier est un template.
# Copier en k8s/secrets.yaml et remplacer les valeurs.
#
# Pour injecter les secrets dans le cluster :
#   kubectl create secret generic aeropath-secrets \
#     --from-literal=database-url="postgres://aeropath:REAL_PASSWORD@postgres:5432/aeropath?sslmode=disable" \
#     --from-literal=jwt-secret="$(openssl rand -base64 32)" \
#     --from-literal=redis-password="$(openssl rand -base64 16)" \
#     --from-literal=clickhouse-password="$(openssl rand -base64 16)"
#
# Ou utiliser Sealed Secrets pour garder des manifests chiffrés dans le repo.

apiVersion: v1
kind: Secret
metadata:
  name: aeropath-secrets
  namespace: aeropath
type: Opaque
stringData:
  database-url: "postgres://aeropath:CHANGE_ME_postgres_password@postgres:5432/aeropath?sslmode=disable"
  jwt-secret: "CHANGE_ME_base64_encoded_jwt_secret_min_32_chars"
  redis-password: "CHANGE_ME_base64_encoded_redis_password"
  clickhouse-password: "CHANGE_ME_base64_encoded_clickhouse_password"