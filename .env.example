# ============================================================
#  ⚠️  NE JAMAIS COMMITTER LE FICHIER .env
#     Copier ce fichier en .env et remplir les valeurs
#     docker compose vérifie que .env existe et l'ignore dans git
# ============================================================

# ─── Base de données (PostgreSQL) ─────────────────────────
POSTGRES_PASSWORD=changer_moi_postgres

# ─── Multi-DB: Licence + Langue ───────────────────────────
# Chaque licence+langue a SA propre base de données
# (15MB pour PPL, 200MB pour ATPL → isolation totale)

# PPL (Private Pilot Licence)
DB_PPL_FR=postgres://aeropath:${POSTGRES_PASSWORD}@postgres:5432/aero_ppl_fr
DB_PPL_EN=postgres://aeropath:${POSTGRES_PASSWORD}@postgres:5432/aero_ppl_en
DB_PPL_ZH=postgres://aeropath:${POSTGRES_PASSWORD}@postgres:5432/aero_ppl_zh
DB_PPL_ES=postgres://aeropath:${POSTGRES_PASSWORD}@postgres:5432/aero_ppl_es
DB_PPL_DE=postgres://aeropath:${POSTGRES_PASSWORD}@postgres:5432/aero_ppl_de

# ATPL (Airline Transport Pilot Licence)
DB_ATPL_FR=postgres://aeropath:${POSTGRES_PASSWORD}@postgres:5432/aero_atpl_fr
DB_ATPL_EN=postgres://aeropath:${POSTGRES_PASSWORD}@postgres:5432/aero_atpl_en

# Shared databases (gamification + config)
DB_GAMIFICATION=postgres://aeropath:${POSTGRES_PASSWORD}@postgres:5432/aero_gamification
DB_CONFIG=postgres://aeropath:${POSTGRES_PASSWORD}@postgres:5432/aero_config


# ─── Redis ───────────────────────────────────────────────
REDIS_PASSWORD=changer_moi_redis

# ─── NATS (pas de mot de passe, basé sur réseau privé) ──

# ─── ClickHouse (analytics) ──────────────────────────────
CLICKHOUSE_PASSWORD=changer_moi_clickhouse

# ─── Application ─────────────────────────────────────────
JWT_SECRET=changer_moi_jwt_secret_tres_long

# ─── Monitoring ──────────────────────────────────────────
GRAFANA_USER=changer_moi_user
GRAFANA_PASSWORD=changer_moi_grafana

# ─── API Gateway (automatique via compose) ─────────────
PORT=8080
GIN_MODE=release
