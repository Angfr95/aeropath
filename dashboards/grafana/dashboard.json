{
  "title": "AeroForge - Monitoring",
  "description": "Dashboard principal AeroForge avec métriques RED, progression étudiants, et santé des services",
  "schemaVersion": 36,
  "panels": [
    {
      "title": "Taux de requêtes (RPS)",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(requests_total[5m])",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "title": "Latence p99",
      "type": "graph",
      "targets": [
        {
          "expr": "histogram_quantile(0.99, rate(request_duration_seconds_bucket[5m]))",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "title": "Taux d'erreur",
      "type": "graph",
      "targets": [
        {
          "expr": "rate(errors_total[5m]) / rate(requests_total[5m])",
          "legendFormat": "{{job}}"
        }
      ]
    },
    {
      "title": "Étudiants actifs",
      "type": "stat",
      "targets": [
        {
          "expr": "aeroforge_active_students"
        }
      ]
    },
    {
      "title": "Progression moyenne",
      "type": "gauge",
      "targets": [
        {
          "expr": "avg(aeroforge_learning_progress)"
        }
      ]
    },
    {
      "title": "Score examens",
      "type": "heatmap",
      "targets": [
        {
          "expr": "aeroforge_exam_score_bucket"
        }
      ]
    },
    {
      "title": "Santé des services",
      "type": "table",
      "targets": [
        {
          "expr": "up{job=~\"aeroforge-.*\"}"
        }
      ]
    },
    {
      "title": "File NATS",
      "type": "graph",
      "targets": [
        {
          "expr": "aeroforge_queue_depth"
        }
      ]
    }
  ]
}
